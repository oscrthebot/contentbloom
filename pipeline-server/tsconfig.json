{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": "..",
    "paths": {
      "@/*": ["./app/*"]
    }
  },
  "include": ["./**/*", "../generator/**/*", "../lib/**/*", "../app/lib/**/*", "../convex/**/*"]
}
